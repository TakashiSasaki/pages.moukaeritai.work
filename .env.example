# ==============================================================================
# GITHUB PAGES AUDITOR - Environment Configuration Template (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DEVELOPMENT & INTEGRATION TESTING ONLY (DO NOT USE IN PRODUCTION)
# ------------------------------------------------------------------------------

# ALLOW_DUMMY_AUTH: Set to "true" to enable dummy authentication ('dummy-token') 
# for local development and test automation. If disabled, backend API calls will 
# strictly require valid Firebase ID tokens signed by the Firebase Auth service.
# - Required: Optional (strictly for local development / CI test suite)
# - Scope: Backend-only, safe to omit in production
ALLOW_DUMMY_AUTH="true"

# ------------------------------------------------------------------------------
# 2. RUNTIME / INFRASTRUCTURE CONFIGURATION
# ------------------------------------------------------------------------------

# PORT: The port number the Express backend will listen on.
# - Required: Optional (Defaults to 3000)
# - Scope: Backend-only (Must be configured to port 3000 behind reverse proxies)
PORT=3000

# APP_URL: The absolute public host URL of this deployment.
# - Required: Yes (For production deep-linking, reporting, and secure proxy origins)
# - Scope: Used in both frontend and backend configurations
# - Note: In AI Studio runtime, this is dynamically injected matching your Cloud Run URL.
APP_URL="https://example.com"

# NODE_ENV: Mode of the active Express Node process.
# - Required: Optional (Defaults to "development")
# - Scope: Backend-only (e.g., "production", "development", "test")
# - Note: Set to "production" in final deployment environments
NODE_ENV="development"

# ------------------------------------------------------------------------------
# 3. AI / GEMINI CAPABILITIES (NOT USED)
# ------------------------------------------------------------------------------
# Note: Google Gemini, GoogleGenAI SDK, or any AI services are NOT used by
# the GitHub Pages Auditor application. No AI models or API calls are queried
# for core auditing, user persistence, configuration, or reporting features.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# 4. FIREBASE CONFIGURATION STRATEGY
# ------------------------------------------------------------------------------
# All client-side and backend Firebase integrations are loaded from the project root 
# configuration file: `firebase-applet-config.json`.
# 
# How it works:
# 1. Frontend: Read dynamically using modern React standard configuration loader.
# 2. Backend: Parsed dynamically during initialization in `server/env.ts` to retrieve the
#    correct `projectId` without necessitating hardcoded shell variables.
# 
# To register / generate this file:
# Call the system's `set_up_firebase` tool. Do not manually copy config blocks here.
# Do not prefix client vars with VITE_ unless strictly required.
