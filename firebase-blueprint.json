{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a persistent Google user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "provider": { "type": "string" }
      },
      "required": ["uid", "provider"]
    },
    "GitHubToken": {
      "title": "GitHubToken",
      "description": "Represents persistent PAT metadata for Google users only. No direct client reads allowed.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "token": { "type": "string" },
        "tokenStorageVersion": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "token", "tokenStorageVersion"]
    },
    "AnonymousSession": {
       "title": "AnonymousSession",
       "description": "Represents a temporary anonymous guest session.",
       "type": "object",
       "properties": {
         "anonymousUid": { "type": "string" },
         "expiresAt": { "type": "string", "format": "date-time" },
         "updatedAt": { "type": "string", "format": "date-time" }
       },
       "required": ["anonymousUid", "expiresAt"]
     },
     "UserSetting": {
       "title": "UserSetting",
       "description": "Represents persistent app preferences or navigation states for standard or guest users.",
       "type": "object",
       "properties": {
         "lastPath": { "type": "string" },
         "updatedAt": { "type": "string", "format": "date-time" }
       },
       "required": ["lastPath"]
     }
    }
  },
  "firestore": {
    "/githubPagesAuditorV2/dev/users/{uid}": {
       "schema": { "$ref": "#/entities/User" },
       "description": "Persistent user profile"
    },
    "/githubPagesAuditorV2/dev/users/{uid}/githubTokens/{tokenId}": {
       "schema": { "$ref": "#/entities/GitHubToken" },
       "description": "PAT storage for persistent users, never read directly by clients"
    },
    "/githubPagesAuditorV2/dev/users/{uid}/settings/{settingId}": {
       "schema": { "$ref": "#/entities/UserSetting" },
       "description": "User specific app parameters and history"
    },
    "/githubPagesAuditorV2/dev/anonymousSessions/{anonymousUid}": {
       "schema": { "$ref": "#/entities/AnonymousSession" },
       "description": "Guest session data"
    },
    "/githubPagesAuditorV2/dev/anonymousSessions/{anonymousUid}/githubTokens/{tokenId}": {
       "schema": { "$ref": "#/entities/GitHubToken" },
       "description": "PAT storage for anonymous users, never read directly by clients"
    },
    "/githubPagesAuditorV2/dev/anonymousSessions/{anonymousUid}/settings/{settingId}": {
       "schema": { "$ref": "#/entities/UserSetting" },
       "description": "Guest specific app parameters and history"
    },
    "/githubPagesAuditorV2/prod/users/{uid}": {
       "schema": { "$ref": "#/entities/User" },
       "description": "Persistent user profile"
    },
    "/githubPagesAuditorV2/prod/users/{uid}/githubTokens/{tokenId}": {
       "schema": { "$ref": "#/entities/GitHubToken" },
       "description": "PAT storage for persistent users, never read directly by clients"
    },
    "/githubPagesAuditorV2/prod/users/{uid}/settings/{settingId}": {
       "schema": { "$ref": "#/entities/UserSetting" },
       "description": "User specific app parameters and history"
    },
    "/githubPagesAuditorV2/prod/anonymousSessions/{anonymousUid}": {
       "schema": { "$ref": "#/entities/AnonymousSession" },
       "description": "Guest session data"
    },
    "/githubPagesAuditorV2/prod/anonymousSessions/{anonymousUid}/githubTokens/{tokenId}": {
       "schema": { "$ref": "#/entities/GitHubToken" },
       "description": "PAT storage for anonymous users, never read directly by clients"
    },
    "/githubPagesAuditorV2/prod/anonymousSessions/{anonymousUid}/settings/{settingId}": {
       "schema": { "$ref": "#/entities/UserSetting" },
       "description": "Guest specific app parameters and history"
    }
  }
}
