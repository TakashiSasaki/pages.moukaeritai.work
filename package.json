{
  "name": "github-pages-auditor",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build --mode production && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "NODE_ENV=test tsx --test tests/**/*.test.ts",
    "test:unit": "NODE_ENV=test tsx --test tests/comprehensive.test.ts",
    "test:rules": "NODE_ENV=test tsx --test tests/rules.test.ts",
    "schema:generate": "ts-json-schema-generator --path src/schema/exportTypesV2.ts --type GitHubPagesAuditorExportV2 --out schemas/github-pages-auditor-export-v2.schema.json && node scripts/applySchemaMetadata.js",
    "schema:check": "node scripts/schemaCheck.js",
    "examples:validate": "node scripts/validateExamples.js",
    "test:examples": "npm run examples:validate",
    "release:check": "node scripts/releaseReadinessCheck.js",
    "smoke:public": "node scripts/publicSmokeCheck.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "react-window": "^2.2.7",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-window": "^1.8.8",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "ts-json-schema-generator": "^2.9.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
